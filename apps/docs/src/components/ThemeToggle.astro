---
// Override of Starlight's default `ThemeSelect` component.
//
// Replaces the segmented control with a single click-to-cycle icon
// button that mirrors the desktop app: auto → light → dark → auto.
// The visible icon reflects the current choice. Persists under the
// same `starlight-theme` localStorage key Starlight's `ThemeProvider`
// reads, so the no-FOUC inline script still resolves the theme before
// paint.
---

<starlight-theme-toggle>
  <button type="button" aria-label="Cycle theme" title="Cycle theme">
    <svg data-icon="auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2"></rect>
      <line x1="8" y1="21" x2="16" y2="21"></line>
      <line x1="12" y1="17" x2="12" y2="21"></line>
    </svg>
    <svg data-icon="light" hidden xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
    <svg data-icon="dark" hidden xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
</starlight-theme-toggle>

<style>
  starlight-theme-toggle button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: transparent;
    color: var(--sl-color-text);
    font: inherit;
    line-height: 0;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  starlight-theme-toggle button:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-white);
  }
  starlight-theme-toggle svg {
    flex: none;
  }
  starlight-theme-toggle svg[hidden] {
    display: none;
  }
</style>

<script>
  type Theme = 'auto' | 'light' | 'dark';

  const STORAGE_KEY = 'starlight-theme';
  const CYCLE: Theme[] = ['auto', 'light', 'dark'];

  function parse(value: unknown): Theme {
    return value === 'light' || value === 'dark' ? value : 'auto';
  }

  function load(): Theme {
    return parse(typeof localStorage !== 'undefined' && localStorage.getItem(STORAGE_KEY));
  }

  function store(theme: Theme): void {
    if (typeof localStorage === 'undefined') return;
    // Match Starlight's convention: empty string means "auto".
    localStorage.setItem(STORAGE_KEY, theme === 'auto' ? '' : theme);
  }

  function effective(theme: Theme): 'light' | 'dark' {
    if (theme !== 'auto') return theme;
    return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function apply(theme: Theme): void {
    document.documentElement.dataset.theme = effective(theme);
    // Keep Starlight's other UI surfaces (e.g. mobile menu select) in
    // sync if they happen to be on the page.
    const provider = (window as unknown as {
      StarlightThemeProvider?: { updatePickers: (t: string) => void };
    }).StarlightThemeProvider;
    provider?.updatePickers(theme === 'auto' ? '' : theme);
  }

  class StarlightThemeToggle extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector('button');
      if (!button) return;

      const refresh = (theme: Theme) => {
        for (const icon of this.querySelectorAll<SVGElement>('[data-icon]')) {
          // `.hidden` IDL property is HTMLElement-only; SVGElement needs
          // an explicit attribute toggle to flip `[hidden]` CSS state.
          icon.toggleAttribute('hidden', icon.dataset.icon !== theme);
        }
      };

      const initial = load();
      apply(initial);
      refresh(initial);

      button.addEventListener('click', () => {
        const current = load();
        const next = CYCLE[(CYCLE.indexOf(current) + 1) % CYCLE.length]!;
        store(next);
        apply(next);
        refresh(next);
      });

      matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (load() === 'auto') apply('auto');
      });
    }
  }

  customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>
