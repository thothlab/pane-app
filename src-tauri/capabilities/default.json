{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permission set for Pane main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "os:default",
    "shell:default",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "validator": "^https://pane\\.thothlab\\.tech/" }]
    }
  ]
}
